# =============================================================================
# UncleZero Server — Environment Configuration Template
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in each value below (generate secrets with the commands shown)
#   3. Never commit .env — it is listed in .gitignore
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ── Auth ──────────────────────────────────────────────────────────────────────

# Long random secret used to sign JWT session tokens.
# Changing this value instantly invalidates all active sessions.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Session duration in seconds (default: 8 hours)
JWT_EXPIRY_SECONDS=28800

# Default admin account — only used on first run if no users exist in the DB.
# Generate password with:  node -e "console.log(require('crypto').randomBytes(16).toString('base64url'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# API key sent by ESP32 devices in the X-Api-Key request header.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ESP32_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────

DB_PATH=data/sensors.db

# How long to keep alert history in milliseconds (default: 30 days)
ALERT_MAX_AGE_MS=2592000000

# ── Sensors ───────────────────────────────────────────────────────────────────

# Mark a sensor OFFLINE after this many ms with no report (default: 25 hours)
OFFLINE_THRESHOLD_MS=90000000
